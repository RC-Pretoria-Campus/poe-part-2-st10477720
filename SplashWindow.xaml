<Window x:Class="Prog_Poe_Part2.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prog_Poe_Part2"
        mc:Ignorable="d"
        Title="SplashWindow" Height="550" Width="800"
        MouseDown="Window_MouseDown">
    
    <Grid Background="Black">
       
        <!-- logo icon -->
        <Image Source="/images/icons8-chatbot-50.png"
               Height="100" Width="100"
               VerticalAlignment="Top"
               HorizontalAlignment="Center"
               Margin="0,60,0,0"/>
        
        <!-- main title -->
        <TextBlock Text="CyAC"
                   FontFamily="Times New Roman"
                   FontSize="80"
                   FontWeight="Bold"
                   Foreground="Cyan"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,0,0,0"/>

        <!-- subtitle -->
        <TextBlock Text="Your Cyber Safety Assisstant"
                   FontFamily="Trebuchet MS"
                   FontSize="22"
                   Foreground="BlueViolet"  
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,110,0,0"/>
        
        <!-- divider line -->
        <Rectangle Height="4"
                   Fill="Cyan"
                   Width="500"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="0,150,0,0"
                   Opacity="0.6"/>

        <TextBlock x:Name="txtSubtitle"
           Text="Playing welcome message..."
           Foreground="Gray"
           FontSize="18"
           HorizontalAlignment="Center"
           Margin="0,20,0,0"/>
        
        <!-- click continue prompt -->
        <TextBlock x:Name="clickPrompt"
                   Text="Click anywhere to continue..."
                   FontFamily="Tw Cen MT"
                   FontSize="22"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,90"/>
    </Grid>
</Window>
