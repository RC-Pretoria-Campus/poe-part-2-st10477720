<Window x:Class="Prog_Poe_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prog_Poe_Part2"
        mc:Ignorable="d"       
    Title="MainWindow" Height="580" Width="800">
    <Grid Background="Black">


        <Image Source="/images/icons8-chatbot-50.png"
               Height="60" Width="60"
               VerticalAlignment="Top"
               HorizontalAlignment="Left"
               Opacity="200"
               Margin="570,8,0,0" />

        <TextBlock Text="CYAC Cybersecurity Bot"
                   Foreground="Cyan"
                   FontSize="24"
                   FontFamily="Arial Black"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,22,0,480" />

        <RichTextBox x:Name="txtChat"
                 Foreground="Blue"    
                 Margin="70,70,70,120"
                 IsReadOnly="True"                
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontSize="14" />

        <TextBox x:Name="txtMessage"               
                 Height="35"
                 Margin="70,0,160,70"
                 VerticalAlignment="Bottom"
                 FontSize="14" 
                 KeyDown="txtMessage_KeyDown"/>

        <Button Content="Send"
                FontWeight="Bold"
                Width="80"
                Height="35"
                Margin="0,0,60,70"
                Background="Plum"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Click="Button_Click" />

        <Button Content="Clear"
                Background="AliceBlue"
                Width="80"
                Height="30"
                Margin="600,480,0,0"
                Click="btnClear_Click"/>    

    </Grid>
</Window>
